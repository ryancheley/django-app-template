# Copy to .env before first run: cp .env.example .env
# Every variable read by compose.yaml or compose.prod.yaml is documented here.

# Django secret key. The dev default in settings.py is NOT safe for production.
SECRET_KEY=change-me-in-production

# "true" enables Django debug mode. Must be "false" in production.
DEBUG=true

# Comma-separated hostnames Django will serve.
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection. These feed both the db container and Django.
POSTGRES_DB=template_project
POSTGRES_USER=template_project
POSTGRES_PASSWORD=dev-only-password
# Inside compose, Django reaches the db service by name; host-side tools use
# localhost:5433 (see compose.yaml port mapping).
POSTGRES_HOST=db
POSTGRES_PORT=5432
